{
  "expo": {
    "name": "CashoutAI",
    "slug": "cashoutai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/cashoutAI_icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/cashoutAI_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#309F38"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.daviddaou.cashoutai",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Camera access is used to scan receipts. Receipt images may be securely sent to OpenAI for AI processing to extract totals, tips, and payment information."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/cashoutAI_icon.png",
        "backgroundColor": "#309F38"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.daviddaou.cashoutai"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "524b2771-3a20-4605-8129-fab14faabf83"
      }
    }
  }
}
